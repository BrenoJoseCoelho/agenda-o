# ============================================================
# Atende AI — variaveis de ambiente
# Copie para .env e preencha. Marcadas com (obrigatorio) sao
# necessarias para o app subir; as demais habilitam features.
# ============================================================

# (obrigatorio) Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:5432/atende_ai?schema=public"

# (obrigatorio) Segredo de sessao do NextAuth. Gere com: openssl rand -hex 32
AUTH_SECRET=""

# (obrigatorio em producao) URL publica do app, sem barra no final.
# Usada nos redirects de OAuth e nos webhooks.
APP_URL="https://app.seudominio.com.br"

# Email do dono da plataforma (você). Só essa conta enxerga o Painel Master
# em /admin (controle de clientes, receita e gastos). Deixe vazio = ninguém.
SUPER_ADMIN_EMAIL=""

# ---- IA (Claude) ----
# Sem a chave, o app usa um motor de fallback (respostas fixas).
ANTHROPIC_API_KEY=""
# Opcional: forca um modelo fixo (senao usa o do plano do cliente:
# Essencial=Haiku, Profissional=Sonnet 5, Ilimitado=Opus 4.8).
ANTHROPIC_MODEL=""

# ---- Transcricao de audio (WhatsApp voice notes) ----
# OpenAI Whisper. Sem a chave, a IA pede o texto ao cliente.
OPENAI_API_KEY=""

# ---- WhatsApp ----
# Token que voce define no painel da Meta para verificar o webhook.
WHATSAPP_VERIFY_TOKEN="troque-por-um-token-secreto"
# App Secret da Meta. Se preenchido, o webhook valida a assinatura
# (X-Hub-Signature-256) de cada requisicao. Recomendado em producao.
WHATSAPP_APP_SECRET=""
# 360dialog (conexao de WhatsApp de 1 clique para o cliente).
# Setup unico da plataforma; sem isso, so o modo avancado (Meta) fica disponivel.
D360_PARTNER_ID=""
D360_PARTNER_API_TOKEN=""

# ---- Google Calendar ----
# Setup unico da plataforma. Redirect URI a cadastrar no Google Cloud:
#   ${APP_URL}/api/integrations/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Automacoes proativas (cron) ----
# Segredo que protege /api/cron/automations. Na Vercel, defina esta env e o
# Vercel Cron envia "Authorization: Bearer <CRON_SECRET>" automaticamente.
CRON_SECRET=""
